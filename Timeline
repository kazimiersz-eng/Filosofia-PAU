<style>
*{box-sizing:border-box;margin:0;padding:0}
.controls{display:flex;align-items:center;gap:10px;margin-bottom:1.1rem;flex-wrap:wrap;padding:0 2px}
.controls label{font-size:13px;color:var(--color-text-secondary)}
.filter-btn{font-size:12px;padding:4px 10px;border:0.5px solid var(--color-border-secondary);border-radius:999px;background:transparent;color:var(--color-text-secondary);cursor:pointer;transition:all .15s}
.filter-btn.active{background:var(--color-background-secondary);color:var(--color-text-primary);border-color:var(--color-border-primary)}
#timeline-wrap{position:relative;width:100%}
#tsv{width:100%;display:block}
.panel{position:absolute;background:var(--color-background-primary);border:0.5px solid var(--color-border-secondary);border-radius:12px;padding:.9rem 1rem;width:290px;z-index:20;opacity:0;pointer-events:none;transition:opacity .18s}
.panel.visible{opacity:1;pointer-events:all}
.pcls{float:right;font-size:15px;cursor:pointer;color:var(--color-text-secondary);line-height:1;margin-left:6px}
.pname{font-size:14px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px}
.pdates{font-size:11px;color:var(--color-text-secondary);margin-bottom:6px}
.ptag{display:inline-block;font-size:11px;padding:2px 8px;border-radius:999px;margin-bottom:7px}
.psec{font-size:11px;color:var(--color-text-secondary);margin-top:6px;font-weight:500;text-transform:uppercase;letter-spacing:.04em}
.pbody{font-size:12px;color:var(--color-text-primary);line-height:1.55;margin-top:3px}
.pinfs{display:flex;flex-wrap:wrap;gap:4px;margin-top:4px}
.ipill{font-size:11px;padding:2px 8px;border-radius:999px;cursor:pointer;border:0.5px solid}
</style>

