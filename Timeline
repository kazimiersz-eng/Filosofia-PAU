<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cronograma Filosófico Interactivo</title>
    <style>
        :root {
            --bg-color: #fcfcf9;
            --primary-text: #333;
            --accent-purple: #6c5ce7;
            --accent-green: #00b894;
            --accent-orange: #e17055;
            --accent-blue: #0984e3;
            --border-light: #e0e0e0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            margin: 0;
            display: flex;
            justify-content: center;
            color: var(--primary-text);
        }

        /* Contenedor Principal */
        .timeline-container {
            position: relative;
            width: 900px;
            padding: 50px 20px;
            display: flex;
        }

        /* Eje de tiempo izquierdo */
        .time-axis {
            width: 100px;
            border-right: 1px solid #ccc;
            position: relative;
            padding-right: 20px;
            text-align: right;
            color: #888;
            font-size: 0.85rem;
        }

        .era-label {
            position: absolute;
            font-weight: bold;
            color: #555;
        }

        /* Espacio de los nodos */
        .nodes-container {
            flex-grow: 1;
            position: relative;
            padding-left: 50px;
        }

        /* Estilo de los Nodos (Botones) */
        .philosopher-node {
            position: absolute;
            padding: 10px 20px;
            border-radius: 8px;
            border: 1.5px solid;
            background: white;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            min-width: 150px;
            text-align: center;
        }

        .philosopher-node:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .node-name { font-weight: bold; display: block; }
        .node-date { font-size: 0.8rem; opacity: 0.8; }

        /* Colores por Era */
        .era-antiguedad { border-color: var(--accent-purple); color: var(--accent-purple); top: 20px; left: 20px; }
        .era-tardia { border-color: var(--accent-green); color: var(--accent-green); top: 250px; left: 20px; }
        .era-media { border-color: var(--accent-green); color: var(--accent-green); top: 450px; left: 80px; }
        .era-moderna { border-color: var(--accent-orange); color: var(--accent-orange); top: 650px; left: 50px; }

        /* Modal / Tarjeta de Detalle */
        #info-card {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 400px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            padding: 25px;
            z-index: 100;
            border: 1px solid var(--border-light);
        }

        .card-header { display: flex; justify-content: space-between; align-items: start; }
        .close-btn { cursor: pointer; font-size: 1.5rem; border: none; background: none; }
        
        .tag {
            display: inline-block;
            background: #e8f8f5;
            color: #16a085;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            margin: 10px 0;
            font-weight: bold;
        }

        h3 { margin: 5px 0; font-size: 1.4rem; }
        .section-title { font-weight: bold; text-transform: uppercase; font-size: 0.75rem; color: #999; margin-top: 15px; display: block; }
        .content-text { font-size: 0.9rem; line-height: 1.4; margin: 5px 0; }

        /* Overlay para cerrar el modal */
        #overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.1);
            z-index: 90;
        }
    </style>
</head>
<body>

<div class="timeline-container">
    <div class="time-axis">
        <div class="era-label" style="top: 0;">Antigüedad<br>427 a.C.</div>
        <div class="era-label" style="top: 250px;">Tardía<br>354 d.C.</div>
        <div class="era-label" style="top: 450px;">E. Media<br>1225</div>
        <div class="era-label" style="top: 650px;">Moderna<br>1596</div>
    </div>

    <div class="nodes-container" id="nodes-list">
        </div>
</div>

<div id="overlay"></div>
<div id="info-card">
    <div class="card-header">
        <div id="card-title-group">
            <h3 id="philosopher-name">Nombre</h3>
            <span id="philosopher-years">Años</span>
        </div>
        <button class="close-btn" onclick="closeCard()">&times;</button>
    </div>
    <div id="philosopher-era" class="tag">Era</div>
    
    <span class="section-title">Contexto Histórico</span>
    <p id="philosopher-context" class="content-text"></p>
    
    <span class="section-title">Ideas Clave</span>
    <p id="philosopher-ideas" class="content-text"></p>
    
    <span class="section-title">Influyó en</span>
    <p id="philosopher-influence" class="content-text"></p>
</div>

<script>
    const data = [
        { id: 1, name: "Platón", years: "427–347 a.C.", era: "Antigüedad clásica", css: "era-antiguedad", context: "Crisis de la polis ateniense tras la Guerra del Peloponeso y condena de Sócrates.", ideas: "Teoría de las Ideas (mundo sensible vs. inteligible). Política en La República. Dualismo alma-cuerpo.", influence: "Base del pensamiento occidental. Neoplatonismo y Agustín." },
        { id: 2, name: "Agustín de Hipona", years: "354–430", era: "Antigüedad tardía", css: "era-tardia", context: "Caída del Imperio romano de Occidente y expansión del cristianismo.", ideas: "Interioridad. Confesiones. Ciudad de Dios. Síntesis de platonismo y cristianismo.", influence: "Filosofía cristiana medieval." },
        { id: 3, name: "Tomás de Aquino", years: "1225–1274", era: "Edad Media / Escolástica", css: "era-media", context: "Auge de las universidades medievales (Bolonia, París). Redescubrimiento de Aristóteles.", ideas: "Síntesis fe-razón. Cinco vías para demostrar a Dios. Ley natural.", influence: "Descartes, Locke, pensamiento católico." },
        { id: 4, name: "Descartes", years: "1596–1650", era: "Modernidad / Racionalismo", css: "era-moderna", context: "Revolución científica y crisis del aristotelismo.", ideas: "Duda metódica. Cogito ergo sum. Dualismo mente-cuerpo.", influence: "Padre de la filosofía moderna." }
    ];

    const nodesList = document.getElementById('nodes-list');
    const infoCard = document.getElementById('info-card');
    const overlay = document.getElementById('overlay');

    // Generar Nodos
    data.forEach(p => {
        const div = document.createElement('div');
        div.className = `philosopher-node ${p.css}`;
        div.innerHTML = `<span class="node-name">${p.name}</span><span class="node-date">${p.years}</span>`;
        div.onclick = () => showDetail(p);
        nodesList.appendChild(div);
    });

    function showDetail(p) {
        document.getElementById('philosopher-name').innerText = p.name;
        document.getElementById('philosopher-years').innerText = p.years;
        document.getElementById('philosopher-era').innerText = p.era;
        document.getElementById('philosopher-context').innerText = p.context;
        document.getElementById('philosopher-ideas').innerText = p.ideas;
        document.getElementById('philosopher-influence').innerText = p.influence;
        
        infoCard.style.display = 'block';
        overlay.style.display = 'block';
    }

    function closeCard() {
        infoCard.style.display = 'none';
        overlay.style.display = 'none';
    }

    overlay.onclick = closeCard;
</script>

</body>
</html>
