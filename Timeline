let showSec=true, showInf=true, activeId=null;
const panel=document.getElementById('panel');
const wrap=document.getElementById('timeline-wrap');

function posPanel(node){
  const wr=wrap.getBoundingClientRect();
  const nr=node.getBoundingClientRect();
  let l=nr.right-wr.left+8, t=nr.top-wr.top;
  if(l+298>wr.width) l=nr.left-wr.left-302;
  if(l<2) l=2;
  if(t+340>wr.height) t=Math.max(0,wr.height-345);
  panel.style.left=l+'px'; panel.style.top=t+'px';
}

function openPanel(id,el){
  const d=D[id]; if(!d) return;
  activeId=id;
  document.getElementById('pname').textContent=d.name;
  document.getElementById('pdates').textContent=d.dates;
  const tag=document.getElementById('ptag');
  tag.textContent=d.era; tag.style.background=d.bg; tag.style.color=d.tc; tag.style.border='0.5px solid '+d.bc;
  document.getElementById('pctx').textContent=d.ctx;
  document.getElementById('pideas').textContent=d.ideas;
  const iw=document.getElementById('pinfwrap'), ie=document.getElementById('pinfs');
  ie.innerHTML='';
  if(d.inf&&d.inf.length){
    iw.style.display='';
    d.inf.forEach(iid=>{
      const d2=D[iid]; if(!d2) return;
      const p=document.createElement('span'); p.className='ipill';
      p.textContent=d2.name; p.style.background=d2.bg; p.style.color=d2.tc; p.style.borderColor=d2.bc;
      p.onclick=()=>{const tn=document.querySelector('[data-id="'+iid+'"]');if(tn)openPanel(iid,tn);};
      ie.appendChild(p);
    });
  } else { iw.style.display='none'; }
  posPanel(el);
  panel.classList.add('visible');
  highlightInf(id);
}

function highlightInf(id){
  document.querySelectorAll('[id^="il-"]').forEach(e=>{
    e.style.opacity=id?'0.1':(showInf?'0.45':'0');
  });
  if(!id) return;
  const low=id.toLowerCase();
  document.querySelectorAll('[id^="il-"]').forEach(e=>{
    if(e.id.includes(low)) e.style.opacity='0.85';
  });
}

document.getElementById('pcls').onclick=()=>{
  panel.classList.remove('visible'); activeId=null;
  document.querySelectorAll('[id^="il-"]').forEach(e=>{ e.style.opacity=showInf?'0.45':'0'; });
};

document.querySelectorAll('.pn').forEach(n=>{
  n.addEventListener('click',()=>openPanel(n.dataset.id,n));
});

document.querySelectorAll('.filter-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const f=btn.dataset.f;
    if(f==='all'||f==='main'){
      document.querySelectorAll('.filter-btn[data-f="all"],[data-f="main"]').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active'); showSec=f==='all';
      document.querySelectorAll('.sec').forEach(n=>{ n.style.display=showSec?'':'none'; });
    }
    if(f==='inf'||f==='noinf'){
      document.querySelectorAll('.filter-btn[data-f="inf"],[data-f="noinf"]').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active'); showInf=f==='inf';
      document.querySelectorAll('[id^="il-"]').forEach(e=>{ e.style.opacity=showInf?'0.45':'0'; });
    }
  });
});
</script>
